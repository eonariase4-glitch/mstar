{
  "name": "dealsight",
  "version": "0.1.0",
  "private": true,
  "description": "DealSight UK property intelligence starter project.",
  "main": "desktop/main.js",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client & npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "desktop:preview": "npm run build --workspace client && electron .",
    "desktop:build": "npm run build --workspace client && electron-builder --linux AppImage --publish never",
    "desktop:dir": "npm run build --workspace client && electron-builder --linux dir --publish never",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "openai": "^6.44.0",
    "pg": "^8.22.0",
    "puppeteer": "^25.2.1"
  },
  "build": {
    "appId": "com.dealsight.desktop",
    "productName": "DealSight",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "client/dist/**/*",
      "server/**/*",
      "database/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Finance"
    },
    "npmRebuild": false
  }
}
